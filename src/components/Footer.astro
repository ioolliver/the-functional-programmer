---
import { LINKEDIN_URL, GITHUB_URL } from "../consts";
---

<footer class="max-w-3xl mx-auto px-6 py-8 border-t border-gray-light">
    <div class="flex justify-between items-center text-sm text-gray">
        <span>Isaque Nascimento</span>
        <div class="flex gap-4">
            <a href={LINKEDIN_URL} target="_blank" class="hover:text-gray-dark transition-colors">LinkedIn</a>
            <span>|</span>
            <a href={GITHUB_URL} target="_blank" class="hover:text-gray-dark transition-colors">GitHub</a>
        </div>
    </div>
</footer>
