---
import {
    SITE_TITLE,
    LINKEDIN_URL,
    GITHUB_URL,
    LINKEDIN_SVG_ICON,
    GITHUB_SVG_ICON,
} from "../consts";
import HeaderLink from "./HeaderLink.astro";
import SocialLink from "./SocialLink.astro";
---

<header class="m-0 px-3 pt-2 md:px-6 bg-white drop-shadow-black">
    <nav class="flex justify-between items-center">
        <h2 class="font-bold text-2xl"><a href="/">{SITE_TITLE}</a></h2>
        <div class="flex gap-4 text-xl">
            <HeaderLink href="/">Home</HeaderLink>
            <HeaderLink href="/blog">Blog</HeaderLink>
        </div>
        <div class="hidden md:flex gap-4">
            <SocialLink
                url={LINKEDIN_URL}
                alternativeText="Connect with me on Linkedin"
                iconCode={LINKEDIN_SVG_ICON}
            />
            <SocialLink
                url={GITHUB_URL}
                alternativeText="Check out my projets on GitHub"
                iconCode={GITHUB_SVG_ICON}
            />
        </div>
    </nav>
</header>
